# Same Postgres as the Next app. Prefer the Supabase SESSION port (5432) for a
# long-running worker; psycopg disables server-side prepares for the pooler too.
DATABASE_URL=postgresql://...:5432/postgres

# Hunter.io — domain search + email verification (gates deliverability).
HUNTER_API_KEY=

# ScrapeGraphAI LLM crawl (optional). Without these the worker uses a basic
# requests+regex crawl instead.
SCRAPEGRAPH_API_KEY=
OPENAI_API_KEY=

# Tuning
MIN_EMAIL_CONFIDENCE=70
BATCH_SIZE=10
POLL_SECONDS=30
MAX_ATTEMPTS=3
