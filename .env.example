# Copy to `.env` for local development and fill in values. In production these
# are set in the Vercel dashboard (Project → Settings → Environment Variables),
# NOT in this file. `.env` is git-ignored and must never be committed.
#
# Scope guidance for Vercel:
#  - Set the DATABASE_URL / Supabase values for the *Production* environment to
#    the REAL Supabase project, and (optionally) the *Preview*/*Development*
#    scopes to the test project.
#  - NEXT_PUBLIC_* values are exposed to the browser — never put secrets there.

# --- Database (Supabase Postgres) -------------------------------------------
# Use the Supabase "Connection pooling" string (port 6543, transaction mode).
DATABASE_URL=

# --- Supabase (auth + client) -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only secret; bypasses RLS — never expose

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=         # e.g. https://your-domain.com in production

# --- Sanity (blog CMS) -------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
SANITY_API_READ_TOKEN=       # only needed for draft preview (optional)
SANITY_API_DEV_TOKEN=        # read+write; only used by scripts/seed-blog.ts (not in prod)

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
NEXT_PUBLIC_FROM_EMAIL=

# --- SMS (Twilio) ------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=
# TWILIO_MESSAGING_SERVICE_SID=   # optional, multi-country sender pool

# --- Web Push (VAPID) --------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=                # e.g. mailto:notifications@your-domain.com

# --- Media (Cloudinary) ------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Maps --------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Admin bootstrap (scripts/create-admin.ts) ------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# --- Analytics (PostHog) -----------------------------------------------------
# Project API key + ingestion host from PostHog (Project → Settings). Both are
# NEXT_PUBLIC_ (the browser SDK needs them); the API key is write-only, safe to
# expose. Browser traffic is reverse-proxied through /ingest (next.config.ts) to
# dodge ad-blockers. Use https://eu.i.posthog.com for the EU cloud.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Background jobs (Inngest) ----------------------------------------------
INNGEST_DEV=1                # 1 for local dev ONLY; never set this in production
# Production only — from Inngest Cloud (or auto-set by the Vercel↔Inngest
# integration). Required for background jobs (lead SMS/email, scheduled tasks).
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
