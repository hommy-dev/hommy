# Test environment — loaded by vitest.setup.ts for unit + integration tests.
# Safe to commit: contains only the local test-DB credentials, stub Supabase
# keys, and PUBLIC Sanity ids. No real secrets here.
#
# Integration tests require a localhost Postgres. Start one with:
#   pnpm test:db:up        (docker compose, maps localhost:54322)
# CI provides the same via a `postgis/postgis` service on :54322.

# Local/CI test Postgres (PostGIS-enabled). The integration guard requires
# DATABASE_URL to point at localhost.
DATABASE_URL=postgres://hommy_test:hommy_test@localhost:54322/hommy_test

# Stub Supabase — no real Supabase is contacted in tests; these only need to be
# present so modules that construct the client at import time don't throw.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=stub-anon-key
SUPABASE_SERVICE_ROLE_KEY=stub-service-role-key

# Sanity public ids (not secrets) — so src/sanity/env.ts doesn't throw when any
# imported module touches the Sanity client during tests.
NEXT_PUBLIC_SANITY_PROJECT_ID=v6wykinx
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
