# Test-only environment — NO secrets. Points at the throwaway Postgres from
# docker-compose.test.yml (pnpm test:db:up). Integration tests refuse to run
# unless DATABASE_URL is localhost, so this file gates them to the test DB.
NODE_ENV=test
DATABASE_URL=postgres://hommy_test:hommy_test@localhost:54322/hommy_test

# Stub Supabase values so modules that read them at import don't throw. Tests
# run as superuser against vanilla Postgres and bypass RLS entirely.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=stub-anon-key
SUPABASE_SERVICE_ROLE_KEY=stub-service-role-key
