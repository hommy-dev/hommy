# Test environment — committed to git. All secrets must remain stub strings.
# Real keys NEVER go here.

# --- Database (dockerized Postgres on host port 54322) ---
DATABASE_URL=postgresql://homei_test:homei_test@localhost:54322/homei_test

# --- Supabase (stubbed; auth is mocked at getRequiredUser boundary) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=stub-anon-key
SUPABASE_SERVICE_ROLE_KEY=stub-service-role-key

# --- External senders (empty → graceful no-op stubs in lib/notifications/*) ---
RESEND_API_KEY=
FROM_EMAIL=test@homei.local
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Cloudinary (mocked; uploads return fixture URLs) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=test-cloud
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=test-preset

# --- Inngest (dev mode) ---
INNGEST_DEV=1

# --- Misc ---
NODE_ENV=test
